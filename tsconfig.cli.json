{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "dist/node-server",
    "rootDir": "packages/node-server/src",
    "declaration": true
  },
  "include": ["packages/node-server/src/**/*.ts"],
  "exclude": ["packages/node-server/src/**/*.test.ts"]
}
