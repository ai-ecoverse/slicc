{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["swift", "swiftlint", "wrangler", "playwright", "sleep", "open"],
  "ignoreDependencies": ["pyodide", "@cloudflare/workers-types", "e2b", "@tessl/cli"],
  "ignore": [
    "dist/**",
    "**/dist/**",
    "packages/swift-launcher/**",
    "packages/swift-server/**",
    "packages/swift-optel/**",
    "packages/vfs-root/**",
    "packages/dev-tools/**",
    "packages/assets/**",
    "**/*.d.ts",
    "packages/webapp/src/stubs/**"
  ],
  "workspaces": {
    ".": {
      "entry": ["vitest.config.ts", "biome.json", ".releaserc.json"],
      "project": ["*.{js,ts,mjs}"]
    },
    "packages/webapp": {
      "entry": [
        "vite.config.ts!",
        "vite-plugins/**/*.ts!",
        "src/ui/main.ts!",
        "src/ui/preview-sw.ts!",
        "src/ui/llm-proxy-sw.ts!",
        "src/ui/slicc-editor-entry.ts!",
        "src/ui/slicc-diff-entry.ts!",
        "src/ui/lucide-icons.ts!",
        "src/ui/rum.js!",
        "src/shims/empty.ts!",
        "src/shims/realm-vendor.ts!",
        "src/shims/stream.ts!",
        "src/shims/http.ts!",
        "src/shims/https.ts!",
        "src/shims/http2.ts!",
        "src/cdp/extension-bridge-transport.ts!",
        "providers/*.ts!",
        "tests/**/*.test.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx,js}!",
        "providers/**/*.ts!",
        "vite-plugins/**/*.ts!",
        "tests/**/*.ts"
      ],
      "ignore": [
        "src/types/**",
        "src/globals.d.ts",
        "tests/e2e/**",
        "tests/integration/**",
        "tests/test-dips.mjs"
      ],
      "ignoreDependencies": [
        "buffer",
        "puppeteer-core",
        "@types/w3c-web-serial",
        "@ai-ecoverse/spoon",
        "@biomejs/wasm-web",
        "@biomejs/js-api",
        "@ffmpeg/core"
      ]
    },
    "packages/chrome-extension": {
      "entry": [
        "vite.config.ts!",
        "src/service-worker.ts!",
        "src/content-script.ts!",
        "src/sidepanel-entry.ts!",
        "src/secrets-entry.ts!",
        "voice-popup.js!",
        "tests/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,js}!", "tests/**/*.ts"],
      "ignore": ["src/chrome.d.ts"],
      "ignoreDependencies": [
        "@imagemagick/magick-wasm",
        "@ffmpeg/core",
        "@earendil-works/pi-ai",
        "@earendil-works/pi-coding-agent"
      ]
    },
    "packages/node-server": {
      "entry": [
        "src/index.ts!",
        "src/electron-main.ts!",
        "src/release-package.ts!",
        "src/publish-chrome-web-store.ts!",
        "src/qa-setup.ts!",
        "src/secrets/index.ts!",
        "tests/**/*.test.ts"
      ],
      "project": ["src/**/*.ts!", "tests/**/*.ts"],
      "ignore": ["tests/integration/**"],
      "ignoreDependencies": ["e2b"]
    },
    "packages/cloudflare-worker": {
      "entry": ["src/index.ts!", "src/preview-worker.ts!", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts!", "tests/**/*.ts"]
    },
    "packages/cherry": {
      "entry": ["src/index.ts!", "src/preview-bootstrap.ts!", "tests/**/*.test.ts"],
      "project": ["src/**/*.ts!", "tests/**/*.ts"],
      "ignoreDependencies": ["jsdom", "@types/jsdom"]
    },
    "packages/cloud-core": {
      "entry": ["src/index.ts!", "src/cone-config/index.ts!", "tests/**/*.test.ts"],
      "project": [
        "src/**/*.ts!",
        "tests/**/*.ts",
        "!tests/fixtures/index.ts!",
        "!tests/fixtures/mem-registry.ts!"
      ]
    },
    "packages/webcomponents": {
      "entry": [
        "src/index.ts!",
        "src/register.ts!",
        "vitest.config.ts",
        ".storybook/main.ts",
        ".storybook/preview.ts",
        ".storybook/feedback-addon/preset.ts",
        ".storybook/feedback-addon/manager.tsx",
        "src/**/*.stories.ts",
        "tests/**/*.test.ts"
      ],
      "project": ["src/**/*.{ts,tsx}!", "tests/**/*.ts", ".storybook/**/*.{ts,tsx}"],
      "ignoreDependencies": ["lit", "react"]
    },
    "packages/spoon": {
      "entry": [
        "src/index.ts!",
        "src/overlay-entry.ts!",
        "build.mjs!",
        "vitest.config.ts",
        ".storybook/main.ts",
        ".storybook/preview.ts",
        "src/**/*.stories.ts",
        "tests/**/*.test.ts"
      ],
      "project": ["src/**/*.ts!", "tests/**/*.ts", ".storybook/**/*.ts"]
    }
  }
}
