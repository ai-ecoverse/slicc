#!/usr/bin/env node
/**
 * slicc-cdp — zero-dependency CDP driver for a running SLICC dev harness.
 *
 * Attaches to the Chrome the harness launched (port auto-detected from
 * /tmp/slicc-dev-harness.log, or pass --port / SLICC_CDP_PORT) and drives
 * the leader tab (matched on the wrangler UI origin — default
 * http://localhost:8787, override with SLICC_UI_ORIGIN for a
 * WRANGLER_PORT-overridden harness). Node 22+ (built-in WebSocket).
 *
 * Usage:
 *   slicc-cdp targets                       # list page targets
 *   slicc-cdp eval '<js expression>'        # evaluate in the leader page
 *   slicc-cdp click '<exact text>'          # shadow-piercing click by text
 *   slicc-cdp select <value>                # set first <select> + fire events
 *   slicc-cdp prompt '<text>'               # type into composer and send
 *   slicc-cdp term '<text>'                 # type into terminal panel + Enter
 *   slicc-cdp term-text [lines]             # read visible terminal buffer (default 15 lines)
 *   slicc-cdp shot <file> [title-substr]    # screenshot leader (or matching target)
 *   slicc-cdp watch <logfile>               # stream console errors/warnings (foreground)
 *   slicc-cdp download <outfile> [trigger-js]  # capture a browser download to <outfile>
 *                                              # (default trigger: avatar-menu Export transcript)
 */

const args = process.argv.slice(2);
const portFlag = args.indexOf('--port');
const port =
  portFlag >= 0
    ? Number(args.splice(portFlag, 2)[1])
    : Number(process.env.SLICC_CDP_PORT) || (await detectPort());
const [cmd, ...rest] = args;

async function detectPort() {
  const { readFileSync } = await import('node:fs');
  try {
    const log = readFileSync('/tmp/slicc-dev-harness.log', 'utf8');
    // Last occurrence wins: a restarted harness appends a fresh
    // "listening" line, so the first match may be a dead port.
    const m = [...log.matchAll(/Chrome CDP listening on port (\d+)/g)].pop();
    if (m) return Number(m[1]);
  } catch {}
  console.error('Cannot detect CDP port — pass --port or set SLICC_CDP_PORT');
  process.exit(1);
}

/** Host of the wrangler UI origin serving the leader tab. */
const uiHost = (() => {
  try {
    return new URL(process.env.SLICC_UI_ORIGIN ?? 'http://localhost:8787').host;
  } catch {
    console.error(`Invalid SLICC_UI_ORIGIN: ${process.env.SLICC_UI_ORIGIN}`);
    process.exit(1);
  }
})();

async function listTargets() {
  let res;
  try {
    res = await fetch(`http://127.0.0.1:${port}/json/list`, {
      signal: AbortSignal.timeout(5000),
    });
  } catch {
    console.error(
      `CDP not reachable on 127.0.0.1:${port} — is the harness running? ` +
        `(stale log port? pass --port or set SLICC_CDP_PORT)`
    );
    process.exit(1);
  }
  const body = await res.text();
  if (!body.trim()) return [];
  return JSON.parse(body);
}

async function connect(titleSubstr) {
  const targets = await listTargets();
  const page = titleSubstr
    ? targets.find((t) => t.type === 'page' && t.title.includes(titleSubstr))
    : targets.find((t) => t.type === 'page' && t.url.includes(uiHost));
  if (!page) {
    console.error(
      titleSubstr ? `no page target matching "${titleSubstr}"` : 'leader tab not found'
    );
    process.exit(1);
  }
  const ws = new WebSocket(page.webSocketDebuggerUrl);
  await new Promise((resolve, reject) => {
    const deadline = setTimeout(
      () => reject(new Error('CDP WebSocket open timed out (10s)')),
      10_000
    );
    ws.onopen = () => {
      clearTimeout(deadline);
      resolve();
    };
    ws.onerror = (err) => {
      clearTimeout(deadline);
      reject(err);
    };
  });
  let id = 0;
  const pending = new Map();
  let onEvent = null;
  // Single message pump for the session: id-bearing frames settle their
  // pending RPC (rejecting on protocol errors); id-less frames are CDP
  // domain events, forwarded to the optional subscriber. Never reassign
  // ws.onmessage — that would sever the RPC pump.
  ws.onmessage = (e) => {
    let m;
    try {
      m = JSON.parse(e.data);
    } catch {
      return; // ignore malformed frames instead of killing the process
    }
    if (m.id && pending.has(m.id)) {
      const p = pending.get(m.id);
      pending.delete(m.id);
      if (m.error) p.reject(new Error(`CDP error: ${m.error.message ?? JSON.stringify(m.error)}`));
      else p.resolve(m);
      return;
    }
    if (!m.id) onEvent?.(m);
  };
  // A dying socket must fail pending calls loudly, not hang them forever.
  ws.onclose = () => {
    for (const p of pending.values()) p.reject(new Error('CDP socket closed'));
    pending.clear();
  };
  // Per-RPC deadline: an alive-but-unresponsive target must fail loudly,
  // not hang an autonomous run. Generous default — evaluate with
  // awaitPromise can legitimately take a while.
  const RPC_TIMEOUT_MS = 30_000;
  const send = (method, params = {}) =>
    new Promise((resolve, reject) => {
      const i = ++id;
      const timer = setTimeout(() => {
        if (pending.delete(i)) reject(new Error(`CDP call timed out (30s): ${method}`));
      }, RPC_TIMEOUT_MS);
      pending.set(i, {
        resolve: (v) => {
          clearTimeout(timer);
          resolve(v);
        },
        reject: (e) => {
          clearTimeout(timer);
          reject(e);
        },
      });
      ws.send(JSON.stringify({ id: i, method, params }));
    });
  const evaluate = async (expression) => {
    const r = await send('Runtime.evaluate', {
      expression,
      returnByValue: true,
      awaitPromise: true,
    });
    if (r.result?.exceptionDetails) {
      throw new Error(r.result.exceptionDetails.exception?.description ?? 'evaluate failed');
    }
    return r.result?.result?.value;
  };
  return {
    ws,
    send,
    evaluate,
    subscribe(fn) {
      onEvent = fn;
    },
  };
}

/**
 * Shadow-piercing element locator, serialized into the page. Prefers
 * visible, actionable, semantically interactive elements: hidden matches
 * (zero rect / checkVisibility() false) rank last so a mounted-but-hidden
 * menu item doesn't shadow the real control, and buttons/links outrank
 * generic div/li containers wrapping the same text.
 */
const FIND_BY_TEXT = `(text, selectors) => {
  const matches = [];
  const walk = (root) => {
    for (const el of root.querySelectorAll('*')) {
      if (el.shadowRoot) walk(el.shadowRoot);
      if (el.matches(selectors)) {
        const t = (el.innerText || el.getAttribute('aria-label') || '').trim().replace(/\\s+/g, ' ');
        if (t === text.replace(/\\s+/g, ' ')) matches.push(el);
      }
    }
  };
  walk(document);
  const visible = (el) => {
    const r = el.getBoundingClientRect();
    // checkOpacity matters: closed menus here hide via ancestor opacity:0
    // + pointer-events:none, which plain checkVisibility() reports visible.
    const cv = el.checkVisibility?.({ checkOpacity: true, checkVisibilityCSS: true }) ?? true;
    return r.width > 0 && r.height > 0 && cv && getComputedStyle(el).pointerEvents !== 'none';
  };
  const rank = (el) => [
    el.matches('button, a, [role=button], [role=option], [role=menuitem]') ? 0 : 1,
    (el.innerText || '').length,
  ];
  return (
    matches
      .filter(visible) // clicking a mounted-but-hidden control is a silent no-op
      .sort((a, b) => {
        const ra = rank(a), rb = rank(b);
        return ra[0] - rb[0] || ra[1] - rb[1];
      })[0] ?? null
  );
}`;

async function clickAt(session, rect) {
  await session.send('Page.bringToFront');
  for (const type of ['mousePressed', 'mouseReleased']) {
    await session.send('Input.dispatchMouseEvent', {
      type,
      x: rect.x,
      y: rect.y,
      button: 'left',
      clickCount: 1,
    });
  }
}

async function pressEnter(session) {
  for (const type of ['keyDown', 'keyUp']) {
    await session.send('Input.dispatchKeyEvent', {
      type,
      key: 'Enter',
      code: 'Enter',
      windowsVirtualKeyCode: 13,
    });
  }
}

const rectExpr = (finder) => `(() => {
  const el = ${finder};
  if (!el) return null;
  el.scrollIntoView({ block: 'center' });
  const r = el.getBoundingClientRect();
  return { x: r.x + r.width / 2, y: r.y + r.height / 2, tag: el.tagName };
})()`;

/** Redact capability/auth query params before printing a target URL. */
function safeTargetUrl(raw) {
  if (!raw) return '';
  try {
    const url = new URL(raw);
    for (const key of ['bridgeToken', 'code', 'access_token', 'id_token', 'token']) {
      if (url.searchParams.has(key)) url.searchParams.set(key, '<redacted>');
    }
    return url.toString();
  } catch {
    return '<invalid URL>';
  }
}

if (cmd === 'targets') {
  for (const t of await listTargets())
    console.log(`${t.type} | ${t.title} | ${safeTargetUrl(t.url).slice(0, 110)}`);
} else if (cmd === 'eval') {
  const session = await connect();
  console.log(JSON.stringify(await session.evaluate(rest.join(' ')), null, 2));
  session.ws.close();
} else if (cmd === 'click') {
  const session = await connect();
  const text = rest.join(' ');
  const rect = await session.evaluate(
    rectExpr(
      `(${FIND_BY_TEXT})(${JSON.stringify(text)}, 'button, [role=button], [role=option], [role=menuitem], a, li, div')`
    )
  );
  if (!rect) {
    console.error('not found:', text);
    process.exit(1);
  }
  await clickAt(session, rect);
  console.log('clicked', JSON.stringify(rect));
  session.ws.close();
} else if (cmd === 'select') {
  const session = await connect();
  const value = rest[0];
  const result = await session.evaluate(`(() => {
    let sel = null;
    const walk = (root) => {
      for (const el of root.querySelectorAll('*')) {
        if (el.shadowRoot) walk(el.shadowRoot);
        if (!sel && el.tagName === 'SELECT') sel = el;
      }
    };
    walk(document);
    if (!sel) return { ok: false, reason: 'no <select> found' };
    sel.value = ${JSON.stringify(value)};
    if (sel.value !== ${JSON.stringify(value)}) {
      return { ok: false, reason: 'option not found: ' + ${JSON.stringify(value)} };
    }
    sel.dispatchEvent(new Event('input', { bubbles: true, composed: true }));
    sel.dispatchEvent(new Event('change', { bubbles: true, composed: true }));
    return { ok: true, selected: sel.value };
  })()`);
  if (!result.ok) {
    console.error(result.reason);
    process.exit(1);
  }
  console.log('selected', result.selected);
  session.ws.close();
} else if (cmd === 'prompt' || cmd === 'term') {
  const session = await connect();
  const text = rest.join(' ');
  const finder =
    cmd === 'prompt'
      ? `(() => { let box = null; const walk = (root) => { for (const el of root.querySelectorAll('*')) { if (el.shadowRoot) walk(el.shadowRoot); if (!box && el.matches('textarea, [contenteditable=\\'true\\']') && el.getBoundingClientRect().height > 0) box = el; } }; walk(document); return box; })()`
      : `(() => { let el = null; const walk = (root) => { for (const e of root.querySelectorAll('*')) { if (e.shadowRoot) walk(e.shadowRoot); if (!el && e.classList?.contains('xterm')) el = e; } }; walk(document); return el; })()`;
  if (cmd === 'term') {
    // The panel state persists across reloads and the rail button TOGGLES,
    // so a blind "Terminal" click can CLOSE an open panel — input then goes
    // into a hidden stale xterm. The rail button exposes the truth via
    // aria-pressed; only click when the panel is actually closed. (Don't
    // use xterm width — slide-out panels keep their layout width when
    // hidden.)
    const panelOpen = () =>
      session.evaluate(`(() => {
        let btn = null;
        const walk = (root) => {
          for (const e of root.querySelectorAll('button')) {
            if (e.shadowRoot) walk(e.shadowRoot);
            if (!btn && (e.innerText || e.getAttribute('aria-label') || '').trim() === 'Terminal')
              btn = e;
          }
          for (const e of root.querySelectorAll('*')) if (e.shadowRoot) walk(e.shadowRoot);
        };
        walk(document);
        return btn?.getAttribute('aria-pressed') === 'true';
      })()`);
    if (!(await panelOpen())) {
      const railRect = await session.evaluate(
        rectExpr(`(${FIND_BY_TEXT})('Terminal', 'button, [role=button]')`)
      );
      if (!railRect) {
        console.error('terminal panel closed and no Terminal rail button found');
        process.exit(1);
      }
      await clickAt(session, railRect);
      await new Promise((r) => setTimeout(r, 1500));
      if (!(await panelOpen())) {
        console.error('Terminal rail click did not open the panel');
        process.exit(1);
      }
    }
    // Kernel session reattach after a reload takes seconds — wait for a
    // shell prompt ('$' on the last row) before typing into the void.
    const promptReady = () =>
      session.evaluate(`(() => {
        const el = ${finder};
        if (!el) return false;
        const lines = el.innerText.split('\\n').map((l) => l.trim()).filter(Boolean);
        return /\\$$/.test(lines[lines.length - 1] ?? '');
      })()`);
    const deadline = Date.now() + 15_000;
    while (!(await promptReady())) {
      if (Date.now() > deadline) {
        console.error('terminal prompt never appeared — kernel session not ready');
        process.exit(1);
      }
      await new Promise((r) => setTimeout(r, 500));
    }
  }
  const rect = await session.evaluate(rectExpr(finder));
  if (!rect) {
    console.error(cmd === 'prompt' ? 'composer not found' : 'terminal not found');
    process.exit(1);
  }
  const typeOnce = async () => {
    await clickAt(session, rect);
    // Let focus settle before typing — sends fired right after other CDP
    // interactions occasionally drop without this.
    await new Promise((r) => setTimeout(r, 500));
    if (cmd === 'term') {
      // A previously dropped send can leave residue in readline's input
      // buffer, which would prefix-corrupt this command (echo-verify
      // checks containment, so it wouldn't catch it). Ctrl+U kills the
      // pending line first.
      for (const type of ['keyDown', 'keyUp']) {
        await session.send('Input.dispatchKeyEvent', {
          type,
          key: 'u',
          code: 'KeyU',
          modifiers: 2,
          windowsVirtualKeyCode: 85,
        });
      }
      await new Promise((r) => setTimeout(r, 150));
    }
    await session.send('Input.insertText', { text });
    await new Promise((r) => setTimeout(r, 300));
    await pressEnter(session);
  };
  // Terminal sends are verifiable: the shell echoes the typed command into
  // the xterm buffer (wrapped at panel width). Count whitespace-stripped
  // occurrences BEFORE and AFTER the send — the count must increase, so a
  // matching echo from an earlier identical command can't false-pass, and
  // a delayed echo is polled for (not blind-retried, which would
  // double-execute side-effecting commands).
  const echoCount = async () => {
    const buf = await session.evaluate(`(() => {
      let el = null;
      const walk = (root) => {
        for (const e of root.querySelectorAll('*')) {
          if (e.shadowRoot) walk(e.shadowRoot);
          if (!el && e.classList?.contains('xterm')) el = e;
        }
      };
      walk(document);
      return el ? el.innerText : '';
    })()`);
    const needle = text.replace(/\s/g, '');
    if (!needle) return 0;
    return buf.replace(/\s/g, '').split(needle).length - 1;
  };
  if (cmd === 'term') {
    const before = await echoCount();
    const echoedSince = async () => (await echoCount()) > before;
    // Poll generously before retrying — a slow echo must not trigger a
    // second execution of a side-effecting command.
    const pollEcho = async (ms) => {
      const deadline = Date.now() + ms;
      while (Date.now() < deadline) {
        if (await echoedSince()) return true;
        await new Promise((r) => setTimeout(r, 400));
      }
      return echoedSince();
    };
    await typeOnce();
    if (!(await pollEcho(5000))) {
      console.error('echo not found in terminal buffer — retrying send once');
      await typeOnce();
      if (!(await pollEcho(5000))) {
        console.error('send failed twice — giving up:', text);
        process.exit(1);
      }
    }
  } else {
    await typeOnce();
  }
  console.log('sent:', text);
  session.ws.close();
} else if (cmd === 'term-text') {
  const session = await connect();
  const lines = Number(rest[0]) || 15;
  const text = await session.evaluate(`(() => {
    let el = null;
    const walk = (root) => {
      for (const e of root.querySelectorAll('*')) {
        if (e.shadowRoot) walk(e.shadowRoot);
        if (!el && e.classList?.contains('xterm')) el = e;
      }
    };
    walk(document);
    if (!el) return null;
    return el.innerText.split('\\n').map((l) => l.trimEnd()).filter(Boolean).slice(-${lines}).join('\\n');
  })()`);
  if (text === null) {
    console.error('terminal not found — open the Terminal panel first');
    process.exit(1);
  }
  console.log(text);
  session.ws.close();
} else if (cmd === 'shot') {
  const [file, titleSubstr] = rest;
  const session = await connect(titleSubstr);
  await session.send('Page.bringToFront');
  await new Promise((r) => setTimeout(r, 300));
  const shot = await session.send('Page.captureScreenshot', { format: 'png' });
  const { writeFileSync } = await import('node:fs');
  writeFileSync(file, Buffer.from(shot.result.data, 'base64'));
  console.log('saved', file);
  session.ws.close();
} else if (cmd === 'download') {
  // Capture an anchor/blob browser download to a host file. Chrome (the
  // harness browser) runs locally, so CDP writes the download to a temp
  // dir on this host that we then copy to <outfile>. Works for the
  // avatar-menu "Export transcript" action (default trigger) or any custom
  // JS that initiates a download.
  const [outfile, ...triggerParts] = rest;
  if (!outfile) {
    console.error('usage: slicc-cdp download <outfile> [trigger-js]');
    process.exit(1);
  }
  const trigger =
    triggerParts.join(' ') ||
    `(() => { const m = document.querySelector('slicc-avatar-menu'); if (!m) throw new Error('slicc-avatar-menu not found'); m.dispatchEvent(new CustomEvent('slicc-avatar-action', { detail: { id: 'export-transcript' }, bubbles: true, composed: true })); return 'dispatched'; })()`;
  const { mkdtempSync, readFileSync, writeFileSync, readdirSync, existsSync } =
    await import('node:fs');
  const os = await import('node:os');
  const path = await import('node:path');
  const dlDir = mkdtempSync(path.join(os.tmpdir(), 'slicc-dl-'));
  const session = await connect();
  // Subscribe BEFORE triggering so no download event is missed.
  let guid = null;
  let suggested = null;
  let state = null;
  session.subscribe((m) => {
    if (m.method === 'Page.downloadWillBegin') {
      guid = m.params.guid;
      suggested = m.params.suggestedFilename;
    }
    if (m.method === 'Page.downloadProgress') state = m.params.state;
  });
  await session.send('Page.enable');
  // Browser-scoped behavior saves the file named by its guid (no picker);
  // fall back to the deprecated page-scoped variant if unsupported.
  try {
    await session.send('Browser.setDownloadBehavior', {
      behavior: 'allowAndName',
      downloadPath: dlDir,
      eventsEnabled: true,
    });
  } catch {
    await session.send('Page.setDownloadBehavior', { behavior: 'allow', downloadPath: dlDir });
  }
  await session.send('Page.bringToFront');
  const triggerResult = await session.evaluate(trigger);
  // Wait for completion — blob downloads are quick but the bundle build
  // (redaction + zip + scoop drain) can take a few seconds.
  const deadline = Date.now() + 30_000;
  while (state !== 'completed') {
    if (state === 'canceled') {
      console.error('download canceled (state=canceled)');
      process.exit(1);
    }
    if (Date.now() > deadline) {
      console.error(`download did not complete within 30s (state=${state ?? 'none'})`);
      process.exit(1);
    }
    await new Promise((r) => setTimeout(r, 300));
  }
  // allowAndName → file saved as <guid>; page fallback keeps its name.
  let srcPath = guid ? path.join(dlDir, guid) : null;
  if (!srcPath || !existsSync(srcPath)) {
    const files = readdirSync(dlDir).filter((f) => !f.endsWith('.crdownload'));
    if (files.length === 0) {
      console.error(`download reported complete but no file landed in ${dlDir}`);
      process.exit(1);
    }
    srcPath = path.join(dlDir, files[0]);
  }
  const bytes = readFileSync(srcPath);
  writeFileSync(outfile, bytes);
  console.log(
    JSON.stringify({
      ok: true,
      outfile,
      suggestedFilename: suggested,
      bytes: bytes.length,
      trigger: triggerResult,
    })
  );
  session.ws.close();
} else if (cmd === 'watch') {
  const logfile = rest[0];
  if (!logfile) {
    console.error('usage: slicc-cdp watch <logfile>');
    process.exit(1);
  }
  const { appendFileSync } = await import('node:fs');
  const session = await connect();
  const log = (line) => appendFileSync(logfile, `${new Date().toISOString()} ${line}\n`);
  // Subscribe BEFORE enabling the domains: Runtime.enable/Log.enable
  // replay buffered events (boot-time console errors!) immediately, and
  // they'd be dropped while onEvent is still null. Subscribing through
  // the session pump — not ws.onmessage — keeps RPC replies routed.
  session.subscribe((m) => {
    if (m.method === 'Runtime.consoleAPICalled' && ['error', 'warning'].includes(m.params.type)) {
      const txt = m.params.args.map((a) => a.value ?? a.description ?? '').join(' ');
      log(`[console.${m.params.type}] ${txt.slice(0, 500)}`);
    }
    if (m.method === 'Runtime.exceptionThrown') {
      log(`[exception] ${JSON.stringify(m.params.exceptionDetails).slice(0, 500)}`);
    }
    if (m.method === 'Log.entryAdded' && ['error', 'warning'].includes(m.params.entry.level)) {
      log(`[log.${m.params.entry.level}] ${m.params.entry.text?.slice(0, 300)}`);
    }
  });
  session.ws.onclose = () => {
    log('=== watcher socket closed — exiting ===');
    process.exit(1);
  };
  await session.send('Runtime.enable');
  await session.send('Log.enable');
  log('=== watcher attached ===');
  console.log(`watching → ${logfile} (Ctrl-C to stop)`);
  setInterval(() => {}, 60_000);
} else {
  console.error('unknown command — see header of this script for usage');
  process.exit(1);
}
