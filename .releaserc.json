{
  "branches": ["main"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/npm",
      {
        "npmPublish": true,
        "provenance": true
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "SLICC_RELEASED_AT=\"$(date -u +'%Y-%m-%dT%H:%M:%SZ')\" npm run build && npm run package:release && chmod +x packages/swift-launcher/sign-and-package.sh && packages/swift-launcher/sign-and-package.sh",
        "publishCmd": "npm run publish:worker && npm run publish:chrome"
      }
    ],
    [
      "@semantic-release/github",
      {
        "failComment": false,
        "failTitle": false,
        "labels": false,
        "assets": [
          "artifacts/release/*.zip",
          "artifacts/release/*.tgz",
          "artifacts/release/release-artifacts.json",
          "artifacts/release/sliccstart-v*.dmg"
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["package.json", "package-lock.json"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
