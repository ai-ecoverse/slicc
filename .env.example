# slicc dev mode defaults — copy to .env and fill in your values.
# These auto-populate localStorage on first load (won't overwrite existing settings).

# LLM Provider: anthropic, openai, azure-ai-foundry, amazon-bedrock, google, etc.
VITE_SLICC_PROVIDER=anthropic

# API key for the selected provider
VITE_SLICC_API_KEY=

# Base URL (required for Azure, Bedrock, Vertex — leave empty for Anthropic/OpenAI)
VITE_SLICC_BASE_URL=

# Model ID (e.g., claude-sonnet-4-20250514, claude-opus-4-20250514)
VITE_SLICC_MODEL=claude-sonnet-4-20250514

# GitHub PAT for git clone in migrate_page tool (optional)
VITE_GITHUB_TOKEN=
