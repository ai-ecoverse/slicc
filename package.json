{
  "name": "sliccy",
  "version": "0.1.0",
  "description": "Browser-based coding agent with thin CLI server",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/node-server/index.js",
  "types": "./dist/node-server/index.d.ts",
  "bin": {
    "slicc": "dist/node-server/index.js"
  },
  "files": [
    "dist/node-server",
    "dist/ui"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-ecoverse/slicc"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "workspaces": [
    "packages/webapp",
    "packages/node-server",
    "packages/chrome-extension",
    "packages/cloudflare-worker",
    "packages/swift-launcher",
    "packages/swift-server"
  ],
  "scripts": {
    "dev": "npx tsx packages/node-server/src/index.ts --dev",
    "dev:electron": "npx tsx packages/node-server/src/index.ts --dev --electron",
    "build": "npm run build -w @slicc/webapp && npm run build -w @slicc/node-server && npm run build -w @slicc/chrome-extension && npm run build -w @slicc/cloudflare-worker && npm run build -w @slicc/swift-server && npm run build -w @slicc/swift-launcher",
    "start": "node dist/node-server/index.js",
    "start:electron": "node dist/node-server/index.js --electron",
    "typecheck": "tsc --noEmit -p tsconfig.cli.json && tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.worker.json",
    "test": "vitest run",
    "test:server-integration": "vitest run --config packages/node-server/tests/integration/server/vitest.config.ts",
    "test:e2e": "npx playwright test --config packages/webapp/tests/e2e/playwright.config.ts",
    "start:extension": "npm run build -w @slicc/chrome-extension && npm run dev -- --profile=extension",
    "lint": "prettier --write . && eslint . --fix",
    "package:release": "node dist/node-server/release-package.js",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^5.0.0",
    "pyodide": "0.29.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "^1.58.2",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@types/node": "^24.0.0",
    "esbuild": "0.28.0",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "semantic-release": "25.0.3",
    "typescript": "^6.0.0",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "vitest": "4.1.2"
  },
  "lint-staged": {
    "**/*.{ts,js,mjs}": [
      "eslint --fix"
    ],
    "**/*.{ts,js,mjs,json,md,css,html,yaml,yml}": [
      "prettier --write"
    ]
  }
}
