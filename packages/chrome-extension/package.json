{
  "name": "@slicc/chrome-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build --config vite.config.ts",
    "dev:extension": "SLICC_EXT_DEV=1 SLICC_EXT_DEV_WATCH=1 vite build --config vite.config.ts --watch",
    "postbuild:check": "bash ../dev-tools/tools/check-extension-rhc.sh",
    "test": "vitest run",
    "test:extension-smoke": "tsx ../dev-tools/tools/extension-smoke-test.ts",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@ai-ecoverse/spoon": "*",
    "@earendil-works/pi-ai": "^0.80.0",
    "@earendil-works/pi-coding-agent": "^0.80.0",
    "@ffmpeg/core": "0.12.10",
    "@imagemagick/magick-wasm": "^0.0.41",
    "@slicc/shared-ts": "*"
  },
  "devDependencies": {
    "js-md5": "^0.8.3",
    "js-sha1": "^0.7.0",
    "js-sha256": "^0.11.1",
    "pako": "^2.0.0"
  }
}
