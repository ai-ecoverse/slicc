{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "plugins": ["./.biome-plugins/no-innerhtml-electron-overlay.grit"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**/*.ts",
      "**/*.tsx",
      "**/*.js",
      "**/*.jsx",
      "**/*.mjs",
      "**/*.cjs",
      "**/*.json",
      "**/*.jsonc",
      "**/*.css",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/.vite/**",
      "!**/playwright-report/**",
      "!**/test-results/**",
      "!**/artifacts/**",
      "!**/.wrangler/**",
      "!**/.worktrees/**",
      "!**/.qa/**",
      "!**/.build/**",
      "!**/package-lock.json",
      "!packages/assets/fonts/**",
      "!packages/swift-launcher/**",
      "!packages/swift-server/**",
      "!packages/ios-app/**",
      "!**/*.min.js",
      "!packages/webapp/src/ui/rum.js",
      "!packages/webapp/src/ui/lucide-icons.ts",
      "!**/tests/fixtures/workflows/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5",
      "arrowParentheses": "always",
      "bracketSpacing": true
    },
    "globals": ["__DEV__"]
  },
  "json": {
    "formatter": {
      "enabled": true,
      "trailingCommas": "none"
    },
    "parser": {
      "allowComments": true,
      "allowTrailingCommas": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": {
            "maxAllowedComplexity": 25
          }
        },
        "noExcessiveLinesPerFunction": {
          "level": "error",
          "options": {
            "maxLines": 150,
            "skipIifes": true
          }
        },
        "noForEach": "off",
        "noBannedTypes": "off",
        "noUselessConstructor": "off",
        "noUselessSwitchCase": "off",
        "noStaticOnlyClass": "off",
        "noUselessFragments": "off",
        "useArrowFunction": "off",
        "useOptionalChain": "error",
        "useLiteralKeys": "off",
        "noImportantStyles": "error"
      },
      "correctness": {
        "noUnusedVariables": {
          "level": "error",
          "options": {
            "ignoreRestSiblings": true
          }
        },
        "noUnusedImports": "error",
        "noUnusedFunctionParameters": "off",
        "noUnusedPrivateClassMembers": "off",
        "useExhaustiveDependencies": "off",
        "noNodejsModules": "off",
        "noUndeclaredVariables": "off",
        "noConstantCondition": "error",
        "noInnerDeclarations": "off",
        "noConstAssign": "error",
        "noPrecisionLoss": "error",
        "noSwitchDeclarations": "off",
        "noUnreachable": "error"
      },
      "style": {
        "useNamingConvention": {
          "level": "warn",
          "options": {
            "strictCase": false,
            "requireAscii": true,
            "conventions": [
              {
                "selector": {
                  "kind": "function"
                },
                "match": "_*(.+?)_*",
                "formats": ["camelCase", "PascalCase"]
              },
              {
                "selector": {
                  "kind": "classMember"
                },
                "match": "_*(.+?)_*",
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "objectLiteralProperty"
                },
                "match": ".*"
              },
              {
                "selector": {
                  "kind": "typeProperty"
                },
                "match": ".*"
              },
              {
                "selector": {
                  "kind": "enumMember"
                },
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              },
              {
                "selector": {
                  "kind": "typeLike"
                },
                "formats": ["PascalCase"]
              },
              {
                "selector": {
                  "kind": "variable"
                },
                "match": "_*\\$?(.+?)_*",
                "formats": ["camelCase", "PascalCase", "CONSTANT_CASE"]
              }
            ]
          }
        },
        "useImportType": "error",
        "useExportType": "error",
        "useConst": "error",
        "useTemplate": "off",
        "useSingleVarDeclarator": "off",
        "useNumberNamespace": "off",
        "useEnumInitializers": "off",
        "useNodejsImportProtocol": "off",
        "useDefaultParameterLast": "off",
        "useExponentiationOperator": "off",
        "useLiteralEnumMembers": "off",
        "noUselessElse": "off",
        "noNonNullAssertion": "off",
        "noParameterAssign": "off",
        "noUnusedTemplateLiteral": "off",
        "noInferrableTypes": "off"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noEmptyBlockStatements": "off",
        "noEmptyInterface": "off",
        "noConfusingVoidType": "off",
        "noAssignInExpressions": "off",
        "noConsole": "off",
        "noShadowRestrictedNames": "off",
        "noImplicitAnyLet": "off",
        "noPrototypeBuiltins": "off",
        "noGlobalIsNan": "off",
        "noControlCharactersInRegex": "off",
        "noSparseArray": "error",
        "noDoubleEquals": {
          "level": "error",
          "options": {
            "ignoreNull": true
          }
        },
        "noDebugger": "error",
        "noDuplicateCase": "error",
        "noIrregularWhitespace": "error",
        "noFunctionAssign": "error",
        "noArrayIndexKey": "off",
        "noEvolvingTypes": "off",
        "noAsyncPromiseExecutor": "off",
        "noThenProperty": "off",
        "noCatchAssign": "off",
        "noFallthroughSwitchClause": "off",
        "noTemplateCurlyInString": "off",
        "useIterableCallbackReturn": "error"
      },
      "performance": {
        "noDelete": "off",
        "noAccumulatingSpread": "off"
      },
      "a11y": {
        "recommended": false
      },
      "security": {
        "recommended": true
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts", "**/*.test.mjs", "**/test-*.mjs"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noConstructorReturn": "off"
          },
          "style": {
            "useNamingConvention": "off"
          },
          "complexity": {
            "noExcessiveCognitiveComplexity": "off",
            "noExcessiveLinesPerFunction": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/webapp/providers/**/*.ts",
        "packages/webapp/src/types/**/*.ts",
        "packages/webapp/src/stubs/**/*.ts",
        "packages/webapp/src/globals.d.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "useNamingConvention": "off"
          }
        }
      }
    },
    {
      "includes": ["**/*.json", "**/*.jsonc", "**/tsconfig*.json", "**/.releaserc.json"],
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "packages/chrome-extension/src/extension-leader-tray.ts",
        "packages/webapp/cloud/app.js",
        "packages/webapp/src/core/context-compaction.ts",
        "packages/webapp/src/scoops/tray-leader-sync.ts",
        "packages/webapp/src/shell/supplemental-commands/convert-command.ts",
        "packages/webapp/src/shell/supplemental-commands/crontask-command.ts",
        "packages/webapp/src/shell/supplemental-commands/ffmpeg-command.ts",
        "packages/webapp/src/shell/supplemental-commands/open-command.ts",
        "packages/webapp/src/shell/supplemental-commands/pdftk-command.ts",
        "packages/webapp/src/shell/supplemental-commands/websocat-command.ts",
        "packages/webapp/src/ui/page-leader-tray.ts",
        "packages/webapp/src/ui/sprinkle-bridge.ts",
        "packages/webapp/src/ui/sprinkle-renderer.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          }
        }
      }
    },
    {
      "includes": [
        "packages/cherry/src/cdp-host-handlers.ts",
        "packages/chrome-extension/src/secrets-entry.ts",
        "packages/cloud-core/src/cone-config/index.ts",
        "packages/cloud-core/src/operations/list.ts",
        "packages/cloud-core/src/operations/start.ts",
        "packages/cloudflare-worker/src/cloud/auth.ts",
        "packages/cloudflare-worker/src/session-tray.ts",
        "packages/node-server/src/chrome-launch.ts",
        "packages/node-server/src/cloud/dispatch.ts",
        "packages/node-server/src/electron-runtime.ts",
        "packages/node-server/src/runtime-flags.ts",
        "packages/webapp/providers/github-copilot.ts",
        "packages/webapp/providers/xai-grok-sanitize.ts",
        "packages/webapp/src/cdp/har-recorder.ts",
        "packages/webapp/src/core/context-compaction.ts",
        "packages/webapp/src/core/image-processor.ts",
        "packages/webapp/src/core/tool-adapter.ts",
        "packages/webapp/src/fs/mount-recovery.ts",
        "packages/webapp/src/fs/mount/backend-local.ts",
        "packages/webapp/src/git/diff.ts",
        "packages/webapp/src/git/git-config.ts",
        "packages/webapp/src/kernel/realm/http-global.ts",
        "packages/webapp/src/kernel/realm/ws-router-page.ts",
        "packages/webapp/src/kernel/remote-sprinkle-vfs.ts",
        "packages/webapp/src/net/handoff-link.ts",
        "packages/webapp/src/net/link-header.ts",
        "packages/webapp/src/providers/built-in/azure-openai.ts",
        "packages/webapp/src/scoops/tray-leader-sync.ts",
        "packages/webapp/src/scoops/tray-webrtc.ts",
        "packages/webapp/src/shell/mcp/oauth.ts",
        "packages/webapp/src/shell/supplemental-commands/afplay-command.ts",
        "packages/webapp/src/shell/supplemental-commands/biome-command.ts",
        "packages/webapp/src/shell/supplemental-commands/cherry-emit-command.ts",
        "packages/webapp/src/shell/supplemental-commands/convert-command.ts",
        "packages/webapp/src/shell/supplemental-commands/crontask-command.ts",
        "packages/webapp/src/shell/supplemental-commands/dig-command.ts",
        "packages/webapp/src/shell/supplemental-commands/esbuild-command.ts",
        "packages/webapp/src/shell/supplemental-commands/extension-media-capture.ts",
        "packages/webapp/src/shell/supplemental-commands/ffmpeg-command.ts",
        "packages/webapp/src/shell/supplemental-commands/fswatch-command.ts",
        "packages/webapp/src/shell/supplemental-commands/hid-command.ts",
        "packages/webapp/src/shell/supplemental-commands/kill-command.ts",
        "packages/webapp/src/shell/supplemental-commands/local-llm-command.ts",
        "packages/webapp/src/shell/supplemental-commands/mcp-command.ts",
        "packages/webapp/src/shell/supplemental-commands/models-command.ts",
        "packages/webapp/src/shell/supplemental-commands/oauth-domain-command.ts",
        "packages/webapp/src/shell/supplemental-commands/oauth-token-command.ts",
        "packages/webapp/src/shell/supplemental-commands/open-command.ts",
        "packages/webapp/src/shell/supplemental-commands/pdftk-command.ts",
        "packages/webapp/src/shell/supplemental-commands/ps-command.ts",
        "packages/webapp/src/shell/supplemental-commands/python-command.ts",
        "packages/webapp/src/shell/supplemental-commands/screencapture-command.ts",
        "packages/webapp/src/shell/supplemental-commands/serial-command.ts",
        "packages/webapp/src/shell/supplemental-commands/serve-command.ts",
        "packages/webapp/src/shell/supplemental-commands/sprinkle-command.ts",
        "packages/webapp/src/shell/supplemental-commands/sqlite-command.ts",
        "packages/webapp/src/shell/supplemental-commands/test-command.ts",
        "packages/webapp/src/shell/supplemental-commands/tsc-command.ts",
        "packages/webapp/src/shell/supplemental-commands/unzip-command.ts",
        "packages/webapp/src/shell/supplemental-commands/usb-command.ts",
        "packages/webapp/src/shell/supplemental-commands/webhook-command.ts",
        "packages/webapp/src/shell/supplemental-commands/websocat-command.ts",
        "packages/webapp/src/skills/install-from-drop.ts",
        "packages/webapp/src/tools/search-tools.ts",
        "packages/webapp/src/ui/oauth-bootstrap.ts",
        "packages/webapp/src/ui/sprinkle-renderer.ts"
      ],
      "linter": {
        "rules": {
          "complexity": {
            "noExcessiveCognitiveComplexity": "off"
          }
        }
      }
    }
  ]
}
