{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "rebaseWhen": "conflicted",
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "vulnerabilityAlerts": {
    "minimumReleaseAge": "0 days",
    "enabled": true
  },
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^packages/swift-launcher/Sliccstart/Models/SwiftLMVersion\\.swift$"],
      "matchStrings": [
        "// renovate: datasource=(?<datasource>.+?) depName=(?<depName>.+?)(?: versioning=(?<versioning>.+?))?\\s+static let pinned = \"(?<currentValue>.+?)\""
      ],
      "datasourceTemplate": "{{datasource}}",
      "versioningTemplate": "{{#if versioning}}{{versioning}}{{else}}semver{{/if}}"
    }
  ],
  "packageRules": [
    {
      "matchPackageNames": ["pyodide"],
      "rangeStrategy": "pin"
    },
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "non-major dependencies",
      "groupSlug": "non-major"
    },
    {
      "matchPackagePrefixes": ["@mariozechner/"],
      "groupName": "mariozechner packages"
    },
    {
      "matchPackagePrefixes": ["@semantic-release/"],
      "groupName": "semantic-release packages"
    },
    {
      "matchPackagePrefixes": ["@xterm/"],
      "groupName": "xterm packages"
    },
    {
      "matchPackageNames": ["s1ntoneli/AppUpdater"],
      "allowedVersions": "<1.0.0"
    },
    {
      "description": "Apply a longer 14-day cooldown for major version bumps, which carry higher risk of breaking changes and are more attractive targets for malicious actors.",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "14 days"
    }
  ]
}
